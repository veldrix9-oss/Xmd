# 1. Create package.json
cat > package.json << 'EOF'
{
  "name": "veldrix-bot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "pino": "^9.0.0"
  }
}
EOF

# 2. Install dependencies
npm install

# 3. Run the bot
node index.js
